{
  "name": "nuxt-cloudflared-tunnel",
  "version": "0.1.0",
  "description": "Nuxt module that opens a Cloudflare Quick Tunnel to the dev server on startup",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decipher/nuxt-cloudflared-tunnel.git"
  },
  "homepage": "https://github.com/Decipher/nuxt-cloudflared-tunnel",
  "bugs": "https://github.com/Decipher/nuxt-cloudflared-tunnel/issues",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "prepare": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare playground",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "untun": "^0.1.3"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.0.0",
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^4.0.0",
    "@nuxt/test-utils": "^3.17.0",
    "eslint": "^9.0.0",
    "nuxt": "^4.0.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "module",
    "cloudflare",
    "tunnel",
    "devtools",
    "storybook",
    "proxy"
  ]
}
