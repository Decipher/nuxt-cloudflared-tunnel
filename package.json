{
  "name": "nuxt-cloudflared-tunnel",
  "version": "0.1.0",
  "description": "Nuxt module that opens a Cloudflare Quick Tunnel to the dev server on startup",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decipher/nuxt-cloudflared-tunnel.git"
  },
  "homepage": "https://github.com/Decipher/nuxt-cloudflared-tunnel",
  "bugs": "https://github.com/Decipher/nuxt-cloudflared-tunnel/issues",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "prepare": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:all": "CLOUDFLARED_STORYBOOK=1 concurrently --names nuxt,storybook -c cyan,magenta \"pnpm dev\" \"pnpm storybook\"",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "lint": "eslint . && markdownlint-cli2",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:commits": "commitlint --from origin/main --to HEAD",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "release": "changelogen --release --push"
  },
  "dependencies": {
    "@nuxt/kit": "^4.0.0",
    "untun": "^0.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.0.0",
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^4.0.0",
    "@nuxt/test-utils": "^3.17.0",
    "@storybook-vue/nuxt": "9.0.1",
    "@storybook/vue3": "9.1.2",
    "@vitest/coverage-v8": "^3.2.6",
    "changelogen": "^0.6.2",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "markdownlint-cli2": "^0.18.1",
    "markdownlint-rule-search-replace": "^1.2.0",
    "nuxt": "^4.0.0",
    "storybook": "9.1.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.5"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "module",
    "cloudflare",
    "tunnel",
    "devtools",
    "storybook",
    "proxy"
  ]
}
